# 2. Intermediate code generation phase of compiler (TAC Generation)

def precedence(op):
    return 1 if op in "+-" else 2 if op in "*/" else 3 if op == "^" else 0

def infix_to_postfix(expr):
    stack, postfix = [], ""
    for char in expr:
        if char.isalnum():
            postfix += char
        elif char == '(':
            stack.append(char)
        elif char == ')':
            while stack[-1] != '(':
                postfix += stack.pop()
            stack.pop()
        else:
            while stack and precedence(stack[-1]) >= precedence(char):
                postfix += stack.pop()
            stack.append(char)
    while stack:
        postfix += stack.pop()
    return postfix

def generate_TAC(postfix):
    stack, temp_count = [], 1
    expr_map = {}
    
    for token in postfix:
        if token.isalnum():
            stack.append(token)
        else:
            op2 = stack.pop()
            op1 = stack.pop()
            expression = f"{op1}{token}{op2}"
            
            if expression in expr_map:
                stack.append(expr_map[expression])
            else:
                temp = f"t{temp_count}"
                print(f"{temp} = {op1} {token} {op2}")
                expr_map[expression] = temp
                stack.append(temp)
                temp_count += 1

expr = input("Enter expression: ")
postfix = infix_to_postfix(expr)
print("Postfix:", postfix)
print("\nThree Address Code:")
generate_TAC(postfix)
